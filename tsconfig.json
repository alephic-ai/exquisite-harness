  "compilerOptions": {
    "lib": ["esnext"],
    "target": "ES2022",
    "tsBuildInfoFile": "tmp/.tsbuildinfo",
    "types": ["node", "bun"]
  },
  "exclude": ["node_modules"],
  "extends": "./tsconfig.base.json",
  "include": ["*.ts", "src/"]
}
